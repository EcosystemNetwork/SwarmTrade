# ══════════════════════════════════════════════════════════════
# SWARM TRADE — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Mock mode requires NO keys — all are optional for simulation.

# ── Kraken Exchange ────────────────────────────────────────
# Required for paper/live trading modes
KRAKEN_API_KEY=
KRAKEN_PRIVATE_KEY=
# API tier: starter | intermediate | pro (affects rate limits)
KRAKEN_TIER=starter
# Set to 1 to use REST API instead of CLI (default: CLI primary)
KRAKEN_USE_REST_API=0

# ── AI Signal Providers (optional) ─────────────────────────
# PRISM/Strykr AI trading signals
PRISM_API_KEY=
# CryptoPanic news sentiment
NEWS_API_KEY=

# ── Blockchain / On-Chain (optional) ───────────────────────
# Private key for ERC-8004 intent signing and Uniswap execution
# DO NOT use mainnet keys unless you understand the risks
PRIVATE_KEY=

# ── Uniswap DEX Execution (optional) ─────────────────────
# Uniswap Trading API key (get from developers.uniswap.org)
UNISWAP_API_KEY=
# Chain ID for DEX execution (default: 8453 = Base)
UNISWAP_CHAIN_ID=8453

# ── Database ──────────────────────────────────────────────
# Postgres connection URL (Neon serverless recommended)
# If not set, falls back to local SQLite (SWARM_DB_PATH)
DATABASE_URL=
# SQLite fallback path (default: swarm.db)
SWARM_DB_PATH=swarm.db
# Postgres connection pool size
SWARM_DB_MIN_POOL=2
SWARM_DB_MAX_POOL=10

# ── Web Dashboard ──────────────────────────────────────────
# Bearer token for dashboard authentication
# Auto-generated on startup if not set
SWARM_DASHBOARD_TOKEN=
# Dashboard port override (default: 8080)
SWARM_DASHBOARD_PORT=8080

# ── Agent Gateway ──────────────────────────────────────────
# Enable external AI agent connections (also auto-enabled with --web)
SWARM_GATEWAY=false
# Master key for gateway authentication (auto-generated if omitted)
SWARM_GATEWAY_KEY=

# ── Trading Mode Override ─────────────────────────────────
# Override mode from env instead of CLI: mock | paper | live
# SWARM_MODE=mock
# Override trading pairs (comma-separated)
# SWARM_PAIRS=ETHUSD,BTCUSD,SOLUSD
# Override starting capital
# SWARM_CAPITAL=10000

# ── Risk Management ───────────────────────────────────────
# All values override CLI defaults when set
# Max daily loss before circuit breaker halts trading (USD)
# SWARM_RISK_MAX_DAILY_LOSS=100
# Max trades per hour
# SWARM_RISK_MAX_TRADES=20
# Max allocation in any single asset (decimal, 0.30 = 30%)
# SWARM_RISK_MAX_CONCENTRATION=0.30
# Max total equity deployed (decimal, 0.80 = 80%)
# SWARM_RISK_MAX_GROSS_EXPOSURE=0.80
# Max single order size (USD)
# SWARM_RISK_MAX_ORDER=5000
# Max simultaneous open positions
# SWARM_RISK_MAX_POSITIONS=5

# ── Circuit Breaker ───────────────────────────────────────
# Drawdown threshold that triggers circuit breaker (USD)
# SWARM_CB_MAX_DRAWDOWN=200
# Cooldown period after circuit breaker trips (seconds)
# SWARM_CB_COOLDOWN=300

# ── Execution ─────────────────────────────────────────────
# Max retries for order execution
# SWARM_EXEC_MAX_RETRIES=3
# Default order type: market | limit
# SWARM_DEFAULT_ORDER_TYPE=market

# ── External APIs (optional, enhance signal quality) ───────
# Etherscan API key for on-chain analytics
ETHERSCAN_API_KEY=
# CoinGecko Pro API key (free tier works without key)
COINGECKO_API_KEY=
# GitHub token for developer activity tracking (GitHubDevAgent)
GITHUB_TOKEN=
# FRED API key for macro economic calendar (MacroCalendarAgent)
# Get free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Smart Money Tracking (SmartMoneyAgent) ───────────────
# Etherscan API for wallet monitoring (free tier: 5 req/s)
# (shares ETHERSCAN_API_KEY above)
# Basescan API for Base chain wallet tracking
BASESCAN_API_KEY=

# ── x402 Agent Payment Gateway ───────────────────────────
# Wallet key for receiving/sending USDC micropayments
# (shares PRIVATE_KEY above, or set separately)
# X402_PRIVATE_KEY=
# Minimum USDC balance to maintain for payments
# X402_MIN_BALANCE=100

# ── LP Rebalance Manager (UniRange pattern) ──────────────
# Range width in basis points (default: 500 = 5%)
# LP_RANGE_BPS=500
# How far out of range before rebalancing (0.0-1.0, default: 0.8)
# LP_REBALANCE_THRESHOLD=0.8

# ── Hardware Wallet Signing (Maki/LeAgent pattern) ───────
# Signing mode: hot_wallet | ledger_usb | secure_enclave
HARDWARE_SIGNER_MODE=hot_wallet
# USD threshold requiring hardware approval (default: 500)
HARDWARE_APPROVE_USD=500
# Ledger derivation path (default: m/44'/60'/0'/0/0)
# LEDGER_DERIVATION_PATH=m/44'/60'/0'/0/0

# ── Agent Registry (Unstoppable Domains identity) ────────
# Unstoppable Domains API key (optional, for .crypto domain naming)
UD_API_KEY=
# Deployed AgentRegistry contract address (optional)
# AGENT_REGISTRY_ADDRESS=
# Chain for agent registry (default: 8453 = Base)
AGENT_REGISTRY_CHAIN=8453

# ── Yield Aggregator ─────────────────────────────────────
# Minimum APY to consider (default: 2.0%)
# YIELD_MIN_APY=2.0
# Minimum USD to trigger harvest (default: 10.0)
# YIELD_HARVEST_THRESHOLD=10.0

# ── Agent Spending Policies ──────────────────────────────
# Strict mode: reject all trades without explicit policy (default: false)
# AGENT_POLICY_STRICT=false
# Default daily cap per agent in USD (default: 10% of capital)
# AGENT_POLICY_DEFAULT_DAILY_CAP=1000

# ══════════════════════════════════════════════════════════════
# MOON DEV TECH — Extended Exchange + Signal Infrastructure
# ══════════════════════════════════════════════════════════════

# ── Hyperliquid DEX (perps, no KYC) ─────────────────────
# Data feeds work without keys. Execution requires wallet key.
# Hyperliquid API URL override (default: public endpoint)
# HYPERLIQUID_API_URL=
# Wallet private key for Hyperliquid execution (EVM key)
HYPERLIQUID_WALLET_KEY=
# Vault address for vault trading (optional)
HYPERLIQUID_VAULT_ADDRESS=

# ── Jupiter DEX (Solana aggregator) ─────────────────────
# Solana RPC endpoint (default: public mainnet-beta)
SOLANA_RPC_URL=
# Solana wallet private key (base58 encoded)
SOLANA_PRIVATE_KEY=
# Solana wallet public address (for Jupiter swap API)
SOLANA_WALLET_ADDRESS=
# Default slippage tolerance in basis points (default: 50 = 0.5%)
# JUPITER_SLIPPAGE_BPS=50

# ── BirdEye (Solana token analytics) ────────────────────
# BirdEye API key (get from birdeye.so — free tier available)
BIRDEYE_API_KEY=
# Chain to monitor (default: solana)
# BIRDEYE_CHAIN=solana

# ── Backtester (strategy validation) ────────────────────
# Directory for cached OHLCV data (default: ./backtest_data)
# BACKTEST_DATA_DIR=./backtest_data

# ── Social Media Agents ─────────────────────────────────
# X/Twitter API v2 Bearer token (for monitoring crypto alpha)
X_BEARER_TOKEN=
# X API credentials (for posting — optional)
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
# Discord webhook for trade notifications
DISCORD_WEBHOOK_URL=
# Discord webhook for alpha signals (separate channel)
DISCORD_ALPHA_WEBHOOK=
# Telegram bot token + chat ID for alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LLM Brain (--hermes flag) ─────────────────────────
# When --hermes is passed, an LLM replaces the rule-based Strategist
# and controls all 80+ agents as its eyes and ears.
# Auto-detects provider from whichever key/url is set.
#
# Provider priority: ANTHROPIC_API_KEY → OPENAI_API_KEY → LLM_API_URL → OLLAMA
# Force one:  LLM_PROVIDER=ollama | openai | anthropic | openai-compat
LLM_PROVIDER=
# Model name — auto-detects if empty
LLM_MODEL=
# Seconds between LLM calls (default: 15)
HERMES_INTERVAL=15
# Max response tokens (default: 1024)
HERMES_MAX_TOKENS=1024
#
# --- Option 1: Ollama (local, free) ---
# ollama pull gemma3   (or any model you want)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=
#
# --- Option 2: OpenAI-compatible (Kimi, Together, vLLM, LM Studio) ---
LLM_API_URL=
LLM_API_KEY=
#
# --- Option 3: OpenAI ---
# OPENAI_API_KEY=
#
# --- Option 4: Anthropic (Claude) ---
# ANTHROPIC_API_KEY=
#
# --- Option 5: External Agent via Gateway WS (OpenClaw/Hermes/IronClaw) ---
# Your agent connects to the gateway WS, receives briefs, sends decisions
BRAIN_GATEWAY_URL=
BRAIN_GATEWAY_KEY=
# Protocol your agent speaks: openclaw | hermes | ironclaw | raw
BRAIN_PROTOCOL=raw

# ── Agent Learning System ───────────────────────────────
# Exploration rate: 0-1, how often to try underperforming agents (default: 0.1)
# LEARNING_EXPLORATION=0.1

# ══════════════════════════════════════════════════════════════
# PHASE 1-40 — ETHGlobal Showcase Integrations
# ══════════════════════════════════════════════════════════════

# ── Commander Gate (AI Trading Robot) ────────────────────
# Fallback mode when LLM is unavailable: strict | conservative | passthrough
# strict: block ALL trades (safest)
# conservative: only high-conviction (>0.8, 3+ signals) pass through
# passthrough: let everything through (not recommended)
COMMANDER_FALLBACK=conservative
# Max seconds to wait for commander approval
COMMANDER_TIMEOUT=30

# ── Price Validation Gate ────────────────────────────────
# Max deviation in basis points for SAFE tier (default: 50 = 0.5%)
PRICE_GATE_SAFE_BPS=50
# Max deviation for WARN tier (default: 200 = 2%)
PRICE_GATE_WARN_BPS=200
# Seconds to wait on WARN before retry
PRICE_GATE_RETRY_DELAY=5
# Max retries on WARN
PRICE_GATE_MAX_RETRIES=3

# ── ERC-4626 Vault ───────────────────────────────────────
# Vault operating mode: simulate | live
VAULT_MODE=simulate
# Deployed vault contract address (required for live mode)
VAULT_ADDRESS=
# Vault manager private key (shares PRIVATE_KEY if not set)
# VAULT_PRIVATE_KEY=
# Chain ID for vault (default: 8453 = Base)
VAULT_CHAIN_ID=8453
# Daily trade volume cap in USD
VAULT_DAILY_LIMIT_USD=50000

# ── Flash Loan Arbitrage ────────────────────────────────
# Mode: simulate | live
FLASHLOAN_MODE=simulate
# Minimum profit after gas to execute (USD)
FLASHLOAN_MIN_PROFIT_USD=5.0
# Max gas price to execute at (gwei)
FLASHLOAN_GAS_CAP_GWEI=50
# Cooldown between same-path arbs (seconds)
FLASHLOAN_COOLDOWN_S=60
# Flashbots Protect RPC for MEV protection (live mode)
FLASHBOTS_RPC=

# ── Uniswap v4 Hooks ────────────────────────────────────
# Operating mode: simulate | live
V4_MODE=simulate
# PoolManager contract address
V4_POOL_MANAGER=
# Position manager contract address
V4_POSITION_MANAGER=
# RPC URL for v4 chain
V4_RPC_URL=

# ── Cross-Chain Coordination ────────────────────────────
# Chains to monitor (comma-separated chain IDs)
CROSSCHAIN_CHAINS=8453,42161,10
# Minimum APY difference to trigger rebalance
CROSSCHAIN_MIN_YIELD_DIFF=2.0
# Max % of capital to move per rebalance
CROSSCHAIN_REBALANCE_PCT=25
# Circle API key for CCTP transfers
CIRCLE_API_KEY=

# ── Rugpull Detection ───────────────────────────────────
# Mode: strict (block suspicious) | warn (log only)
RUGPULL_MODE=strict
# Minimum contract age in days to trade
RUGPULL_MIN_AGE_DAYS=7
# Minimum liquidity in USD to trade
RUGPULL_MIN_LIQ_USD=50000

# ── Prediction Market Trading ────────────────────────────
# Mode: simulate | live
POLYMARKET_MODE=simulate
# Kelly fraction for bet sizing (default: 0.15)
PREDICTION_KELLY_FRAC=0.15
# Minimum edge to place bet (0.05 = 5%)
PREDICTION_MIN_EDGE=0.05

# ── Strategy NFT ────────────────────────────────────────
# Mode: simulate | live
STRATEGY_NFT_MODE=simulate
# Deployed NFT contract address
STRATEGY_NFT_CONTRACT=
# Default royalty in basis points (500 = 5%)
STRATEGY_NFT_ROYALTY_BPS=500

# ── AI Brain (Multi-Model Adapter) ──────────────────────
# Provider: anthropic | openai | groq | deepseek | local
AI_BRAIN_PROVIDER=groq
# Model override (auto-detected per provider if empty)
AI_BRAIN_MODEL=
# API key for the chosen provider
AI_BRAIN_API_KEY=
# Base URL for local/custom endpoints
AI_BRAIN_BASE_URL=
# Max response tokens
AI_BRAIN_MAX_TOKENS=1024

# ── Telegram Trading Bot ────────────────────────────────
# Bot token from @BotFather (required to enable)
# TELEGRAM_BOT_TOKEN=  (shared with Social Media section above)
# Comma-separated authorized chat IDs
# TELEGRAM_CHAT_ID=  (shared with Social Media section above)
# Separate chat ID for alert notifications
TELEGRAM_ALERT_CHAT=

# ── Voice Trading ───────────────────────────────────────
# STT provider: openai | local | browser (default: browser)
VOICE_PROVIDER=browser
# OpenAI API key for Whisper (if provider=openai)
# VOICE_API_KEY=
# Language code
VOICE_LANGUAGE=en

# ── Agent Factory ───────────────────────────────────────
# Max concurrent spawned agents
FACTORY_MAX_CONCURRENT=10

# ── Social Alpha Scanner v2 ─────────────────────────────
# Minimum engagement velocity to trigger signal (per minute)
SOCIAL_ALPHA_MIN_VELOCITY=0.5

# ── Whale Mirror Agent ──────────────────────────────────
# Max % of portfolio to mirror per whale trade
MIRROR_MAX_PCT=5
# Max USD per mirror trade
MIRROR_MAX_USD=2000

# ── Token Launch Sniper ─────────────────────────────────
# Max USD per snipe entry
SNIPER_MAX_ENTRY=100
# Minimum liquidity to consider
SNIPER_MIN_LIQ=5000

# ── Liquidation Shield ──────────────────────────────────
# Auto-deleverage percentage when health hits danger zone
SHIELD_DELEVERAGE_PCT=25

# ── Portfolio Insurance ─────────────────────────────────
# Max annual hedging cost as % of portfolio
INSURANCE_MAX_COST_PCT=2.0

# ── MEV Protection ──────────────────────────────────────
# Protection mode: flashbots | private_mempool | commit_reveal
MEV_PROTECTION=flashbots
